{
  "manifest_version": 2,
  "name": "Web Time",
  "version": "2.8.0",
  "description": "Track and take control of your time.",
  
  "permissions": [
    "tabs",
    "<all_urls>",
    "storage"
  ],

  "browser_action": {
    "default_icon": {
      "128": "images/icon128.png"
    },
    "default_title": "Web Time",
    "default_popup": "popup/popup.html"
  },

  "icons": {
    "128": "images/icon128.png"
  },
  
  "background": {
    "scripts": ["dist/background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "css": ["timer.css"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "webtime@somedomain.com",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
